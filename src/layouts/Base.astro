---
import { CATEGORIES, CALC_INDEX } from "../lib/calculators.js";
import { shortName } from "../lib/display.js";

// Derived, not hardcoded: a static "80+" overstated the actual count (77).
const calcCount = Object.keys(CALC_INDEX).length;
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  activeId?: string;
  breadcrumbs?: { name: string; url?: string }[];
  jsonLd?: unknown[];
}

const { title, description, activeId, breadcrumbs = [], jsonLd = [] } = Astro.props;

// Astro.site comes from astro.config.mjs (CF_PAGES_URL / SITE_URL). Every page now
// has a real, absolute, unique URL — which is what makes canonical, og:url and the
// sitemap meaningful. Under the old hash router all 77 calculators shared one URL.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
// Site-wide social card (public/og-image.png, generated by scripts/gen-og-image.mjs).
// Absolute URL — social scrapers reject relative paths.
const ogImage = new URL("/og-image.png", Astro.site).href;

// WebSite is stated on every page. Deliberately NOT included: SoftwareApplication,
// whose rich result requires an aggregateRating or review — KakouCalc has neither,
// and inventing ratings would be a fabricated record and a manual-action risk.
// Also not included: FAQPage. Google removed FAQ rich results on 2026-05-07.
// Organization as the named publisher — an honest E-E-A-T signal (who stands
// behind the site). No logo/social/aggregateRating is asserted because none
// genuinely exists yet; inventing them is a fabricated-record risk.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "KakouCalc",
  url: Astro.site?.href,
  description: "Independent publisher of free, independently verified financial calculators.",
};
const siteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "KakouCalc",
  description: "Free financial, investment, loan, retirement and stock calculators.",
  url: Astro.site?.href,
  publisher: { "@type": "Organization", name: "KakouCalc", url: Astro.site?.href },
};

const schemas = [siteSchema, orgSchema, ...jsonLd];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Inlined and render-blocking on purpose: applying the stored theme before
      // first paint is what prevents a flash of the wrong theme. Dark is the
      // default, so only an explicit stored choice overrides it.
      try {
        var t = localStorage.getItem("kakoucalc-theme");
        document.documentElement.dataset.theme = t === "light" ? "light" : "dark";
      } catch (e) {}
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0a0b0d" />
    {/* Google AdSense — account verification + Auto Ads (publisher
        ca-pub-7652735657118192). is:inline so Astro emits it verbatim in the
        <head> of every page, which is what AdSense's reviewer looks for. */}
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7652735657118192"
      crossorigin="anonymous"
      is:inline
    ></script>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="KakouCalc" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="KakouCalc — free financial calculators" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Outfit is Trace's display face and carries the headlines. Inter runs the
         UI. IBM Plex keeps the financial voice: Plex Sans sets the figures — it
         has the tabular numerals the result panel depends on, which Outfit does
         not — Plex Sans Condensed the ledger-column labels, and Plex Mono the
         dense amortization grid. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@600;700&family=IBM+Plex+Sans+Condensed:wght@600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <header class="topbar">
      <button class="icon-btn" id="menuToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="sidebar" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <a class="brand" href="/">
        <span class="brand-mark"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><path d="M8 10h.01"/><path d="M12 10h.01"/><path d="M16 10h.01"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><line x1="16" y1="14" x2="16" y2="18"/></svg></span>
        <span class="brand-name">Kakou<strong>Calc</strong></span>
      </a>
      <div class="search-wrap">
        <svg class="search-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input id="globalSearch" type="search" placeholder={`Search ${calcCount} calculators…`} autocomplete="off" aria-label="Search calculators" />
        <kbd class="search-kbd">/</kbd>
        <div id="searchResults" class="search-results" hidden></div>
      </div>
      <button class="icon-btn" id="themeToggle" aria-label="Toggle theme" title="Toggle dark mode" type="button">
        <svg class="icon-moon" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        <svg class="icon-sun" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
      </button>
    </header>

    <div class="layout">
      <aside class="sidebar" id="sidebar">
        <nav id="nav">
          {
            CATEGORIES.map((cat) => {
              const isOpen = cat.calcs.some((c) => c.id === activeId);
              return (
                <div class={`nav-cat${isOpen ? " open" : ""}`} data-cat={cat.id}>
                  <button type="button" class="nav-cat-head" aria-expanded={String(isOpen)} aria-controls={`navcat-${cat.id}`}>
                    <span class="nav-cat-ico" aria-hidden="true">{cat.icon}</span>
                    <span class="nav-cat-name">{cat.name}</span>
                    <span class="nav-cat-count">{cat.calcs.length}</span>
                    <span class="nav-cat-chev" aria-hidden="true">›</span>
                  </button>
                  <div class="nav-cat-body" id={`navcat-${cat.id}`}>
                    <div class="nav-cat-inner">
                      {cat.calcs.map((c) => (
                        <a href={`/calc/${c.id}`} data-id={c.id} title={c.name} class={c.id === activeId ? "active" : undefined}>
                          {shortName(c.name)}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              );
            })
          }
        </nav>
      </aside>
      <button class="scrim" id="scrim" type="button" tabindex="-1" aria-hidden="true"></button>

      <main class="content" id="content">
        {
          breadcrumbs.length > 0 && (
            <nav class="crumbs" aria-label="Breadcrumb">
              {breadcrumbs.map((b, i) => (
                <>
                  {b.url ? <a href={b.url}>{b.name}</a> : <strong>{b.name}</strong>}
                  {i < breadcrumbs.length - 1 && <span aria-hidden="true">/</span>}
                </>
              ))}
            </nav>
          )
        }
        <slot />
      </main>
    </div>

    <footer class="footer">
      {/* AdSense compliance requires the trust pages (About, Contact, Privacy,
          Terms) reachable from every page — this footer is that guarantee. */}
      <nav class="footer-nav" aria-label="Site">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/methodology">Methodology</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </nav>
      <p>KakouCalc — for educational purposes only. Not financial advice. Verify figures independently.</p>
    </footer>

    <script>
      import "../scripts/ui.js";
    </script>
  </body>
</html>
